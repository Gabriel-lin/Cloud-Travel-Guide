# =============================================================================
# Cloud Travel Guide — repository root
# Stack-specific rules live in frontend/.gitignore and backend/.gitignore
# =============================================================================

# --- Operating system ---
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# --- Environment & secrets (keep *.example tracked) ---
.env
.env.*
!.env.example
!.env.*.example
!**/.env.example

# --- Logs, dumps, temp ---
*.log
debug.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.tmp
*.temp
*.bak
*.swp
*.swo
*~

# --- IDE & editors (shared .vscode/launch.json etc. may stay tracked) ---
.idea/
*.iml
.vscode/*
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/settings.json

# --- Rust / Cargo (repo-wide; e.g. future native modules) ---
/target/
debug/
**/*.rs.bk
**/mutants.out*/
*.pdb

# --- Python bytecode (any package in the monorepo) ---
__pycache__/
*.py[cod]
*$py.class
.Python
*.so

# --- Node (accidental root-level installs) ---
node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# --- Test & coverage (generic) ---
coverage/
.nyc_output/
*.lcov

# --- Build & distribution artifacts (any subproject) ---
**/dist/
**/build/
!**/build/.gitkeep

# --- Electron unpack dirs (electron-builder) ---
**/win-unpacked/
**/linux-unpacked/
**/mac-unpacked/

# --- Docker local overrides ---
docker-compose.override.yml
docker-compose.*.local.yml

# --- Misc local tooling ---
.cache/
.turbo/
.vercel/
.codegraph/
*.tsbuildinfo
