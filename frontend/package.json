{
  "name": "cloud-travel-guide",
  "version": "0.1.0",
  "description": "A travel guide application built with Next.js and Electron",
  "author": {
    "name": "gabriel lin",
    "email": "2823283465@qq.com"
  },
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "electron:dev": "concurrently -k \"cross-env BROWSER=none npm run dev\" \"npm run electron:start\"",
    "electron:start": "wait-on tcp:3000 && cross-env NODE_ENV=development bash scripts/electron-start.sh",
    "electron:build": "cross-env ELECTRON_BUILD=true next build && electron-builder -c.extraMetadata.main=electron/main.js",
    "electron": "cross-env ELECTRON_BUILD=true next build && electron electron/main.js --no-sandbox"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.5.0",
    "d3": "^7.9.0",
    "d3-flame-graph": "^4.1.3",
    "echarts": "^5.6.0",
    "echarts-for-react": "^3.0.2",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^2.15.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/d3": "^7.4.3",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^36.4.0",
    "electron-builder": "^26.0.12",
    "@eslint/eslintrc": "^3.3.1",
    "eslint": "^9.28.0",
    "eslint-config-next": "^16.2.6",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.5",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.0",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.example.cloudtravelguide",
    "productName": "Cloud Travel Guide",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "target": "universal",
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": [
        "nsis",
        "portable",
        "msi"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "maintainer": "gabriel lin <2823283465@qq.com>"
    },
    "electronDownload": {
      "cache": "~/.electron"
    }
  }
}
